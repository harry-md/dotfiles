[Default Applications]
# Browser / Web Handlers
text/html=helium.desktop
x-scheme-handler/http=helium.desktop
x-scheme-handler/https=helium.desktop
x-scheme-handler/ftp=helium.desktop
application/xhtml+xml=helium.desktop
application/xhtml_xml=helium.desktop
application/rdf+xml=helium.desktop
application/rss+xml=helium.desktop
application/xml=helium.desktop
text/xml=helium.desktop

# Other Applications
application/pdf=org.pwmt.zathura.desktop
application/sql=io.dbeaver.DBeaver.desktop
x-scheme-handler/jetbrains=jetbrainsd.desktop

# Handlers you explicitly left blank
x-scheme-handler/ipfs=
x-scheme-handler/ipns=
x-scheme-handler/discord=vesktop.desktop
x-scheme-handler/bruno=bruno.desktop
x-scheme-handler/readest=readest-handler.desktop
x-scheme-handler/clickup=ClickUp.desktop
x-scheme-handler/about=helium.desktop
x-scheme-handler/unknown=helium.desktop
x-scheme-handler/mailto=helium.desktop
